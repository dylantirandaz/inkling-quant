+static void ggml_backend_sched_iql_audit(ggml_backend_sched_t sched, struct ggml_cgraph * graph) {
+    size_t backend_compute_counts[GGML_SCHED_MAX_BACKENDS] = {};
+    size_t compute_count = 0;
+    size_t gpu_count = 0;
+    size_t cpu_count = 0;
+    size_t accelerator_count = 0;
+    size_t other_count = 0;
+    size_t unassigned_count = 0;
+    size_t cpu_diagnostics = 0;
+
+    for (int i = 0; i < graph->n_nodes; ++i) {
+        struct ggml_tensor * node = graph->nodes[i];
+        if (node->op == GGML_OP_NONE || ggml_is_view_op(node->op)) {
+            continue;
+        }
+
+        ++compute_count;
+        const int backend_id = tensor_backend_id(node);
+        if (backend_id < 0 || backend_id >= sched->n_backends) {
+            ++unassigned_count;
+            continue;
+        }
+
+        ++backend_compute_counts[backend_id];
+        ggml_backend_t backend = sched->backends[backend_id];
+
+        ggml_backend_dev_t device = ggml_backend_get_device(backend);
+        if (device == NULL) {
+            ++unassigned_count;
+            continue;
+        }
+
+        switch (ggml_backend_dev_type(device)) {
+            case GGML_BACKEND_DEVICE_TYPE_GPU:
+            case GGML_BACKEND_DEVICE_TYPE_IGPU:
+                ++gpu_count;
+                break;
+            case GGML_BACKEND_DEVICE_TYPE_CPU:
+                ++cpu_count;
+                if (cpu_diagnostics < 8) {
+                    GGML_LOG_INFO(
+                            "IQL_SMOKE_CPU_NODE_V1 graph_uid=%" PRIu64 " ordinal=%d op=%s name=%s\n",
+                            graph->uid,
+                            i,
+                            ggml_op_name(node->op),
+                            node->name);
+                    ++cpu_diagnostics;
+                }
+                break;
+            case GGML_BACKEND_DEVICE_TYPE_ACCEL:
+                ++accelerator_count;
+                break;
+            case GGML_BACKEND_DEVICE_TYPE_META:
+                ++other_count;
+                break;
+        }
+    }
+
+    for (int backend_id = 0; backend_id < sched->n_backends; ++backend_id) {
+        if (backend_compute_counts[backend_id] == 0) {
+            continue;
+        }
+
+        ggml_backend_t backend = sched->backends[backend_id];
+        ggml_backend_dev_t device = ggml_backend_get_device(backend);
+        const char * device_name = "null";
+        const char * device_type_name = "unassigned";
+        if (device != NULL) {
+            device_name = ggml_backend_dev_name(device);
+            switch (ggml_backend_dev_type(device)) {
+                case GGML_BACKEND_DEVICE_TYPE_CPU:
+                    device_type_name = "cpu";
+                    break;
+                case GGML_BACKEND_DEVICE_TYPE_GPU:
+                    device_type_name = "gpu";
+                    break;
+                case GGML_BACKEND_DEVICE_TYPE_IGPU:
+                    device_type_name = "igpu";
+                    break;
+                case GGML_BACKEND_DEVICE_TYPE_ACCEL:
+                    device_type_name = "accel";
+                    break;
+                case GGML_BACKEND_DEVICE_TYPE_META:
+                    device_type_name = "meta";
+                    break;
+            }
+        }
+
+        GGML_LOG_INFO(
+                "IQL_SMOKE_BACKEND_IDENTITY_V1 graph_uid=%" PRIu64 " backend_index=%d backend_name=%s device_name=%s device_type=%s compute=%zu\n",
+                graph->uid,
+                backend_id,
+                ggml_backend_name(backend),
+                device_name,
+                device_type_name,
+                backend_compute_counts[backend_id]);
+    }
+
+    GGML_LOG_INFO(
+            "IQL_SMOKE_BACKEND_GRAPH_V1 graph_uid=%" PRIu64 " phase=post_assignment_pre_split scope=non_view_compute compute=%zu gpu=%zu cpu=%zu accel=%zu other=%zu unassigned=%zu\n",
+            graph->uid,
+            compute_count,
+            gpu_count,
+            cpu_count,
+            accelerator_count,
+            other_count,
+            unassigned_count);
+}
